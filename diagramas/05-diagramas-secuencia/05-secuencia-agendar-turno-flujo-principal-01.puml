@startuml 05-secuencia-agendar-turno-flujo-principal-01
title Diagrama de Secuencia: Agendar Turno Médico (Flujo Principal)

actor Paciente
actor Secretaria
participant "PantallaTurnos:UI" as UI
participant "ServicioTurnos:Servicio" as Servicio
participant "turno:Turno" as Turno
participant "agenda:Agenda" as Agenda
participant "notificacion:Notificacion" as Notif
actor Médico

autonumber

Paciente -> Secretaria: solicitarAgendarTurno(paciente, especialidad)
Secretaria ->> UI: buscarDisponibilidad(especialidad, fecha)
UI -> Servicio: obtenerSlotsDisponibles(especialidad, rangoFechas)
Servicio -> Agenda: consultarDisponibilidad(medico, especialidad)
Agenda --> Servicio: slotsLibres
Servicio --> UI: slotsDisponibles
UI --> Secretaria: opcionesDisponibles
Secretaria ->> Paciente: mostrarAlternativas(opciones)
Paciente ->> Secretaria: seleccionarSlot(fecha, hora)
Secretaria ->> UI: confirmarSeleccion(slot)
UI -> Servicio: crearTurnoMedico(paciente, medico, slot)
create Turno
Servicio -> Turno: new Turno(paciente, medico, slot, estado)
Turno -> Turno: inicializarTurno()
note right of Turno
  Estado: PENDIENTE_CONFIRMACION
  Turno: generado automático
  Timestamp: now()
end note
Turno --> Servicio: turnoCreado
Servicio -> Agenda: registrarTurnoEnAgenda(turno)
Agenda -> Agenda: actualizarSlotsOcupados(medico, slot)
Agenda --> Servicio: registroConfirmado
create Notif
Servicio -> Notif: new Notif(notificacion, "turnoAgendado")
Notif -> Notif: enviarNotificacion(pacienteEmail, turnoDetalles)
Notif --> Servicio: envioExitoso
Servicio --> UI: turnoAgendado
UI ->> Secretaria: mostrarComprobante(comprobante)
Secretaria ->> Paciente: entregarComprobante(numeroTurno, fecha, hora)
Secretaria -> Médico: notificarNuevoTurno(numeroTurno, pacienteNombre)
Médico -> Médico: actualizarAgendaPersonal(numeroTurno)
Médico --> Secretaria: confirmacion
destroy Notif

@enduml
