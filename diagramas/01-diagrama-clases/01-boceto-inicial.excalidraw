{
  "type": "excalidraw",
  "version": 2,
feature/diseñador-de-clases-iniciales-correccion
  "source": "https://marketplace.visualstudio.com/items?itemName=pomdtr.excalidraw-editor",
=======
  "source": "chatgpt",
 release/entrega-final-correcta
classDiagram
direction TB

class Persona {
  -nombre : String
  -telefono : String
  -email : String
}

class Paciente {
  -dni : String
  -obraSocial : String
  +solicitarTurno()
  +cancelarTurno()
}

class Profesional {
  -especialidad : String
  +definirDisponibilidad()
  +autorizarSobreturno() : bool
}

class Secretaria {
  +agendarTurno()
  +reprogramarTurno()
  +cancelarTurno()
  +registrarPresencia()
}

class Agenda {
  -turnos : List~Turno~
  -disponibilidades : List~Disponibilidad~
  +reservarTurno(t : Turno)
  +reservarSobreturno(t : Turno)
  +reprogramarTurno(t : Turno, nuevoHorario : IntervaloTiempo)
  +cancelarTurno(t : Turno)
  +validarDisponibilidad(horario : IntervaloTiempo) : bool
  +verificarConflicto(horario : IntervaloTiempo) : bool
  +mostrarAgendaDiaria(fecha : Date)
  +mostrarAgendaSemanal(fechaInicio : Date)
}

class Turno {
  -estado : EstadoTurno
  -intervalo : IntervaloTiempo
  +reprogramar(nuevoHorario : IntervaloTiempo)
  +cambiarEstado(nuevoEstado : EstadoTurno)
}

class Disponibilidad {
  -intervalo : IntervaloTiempo
  -tipo : String
  +esValida(horario : IntervaloTiempo) : bool
  +coincideConTurno(horario : IntervaloTiempo) : bool
}

class IntervaloTiempo {
  -inicio : DateTime
  -fin : DateTime
  +seSuperponeCon(otro : IntervaloTiempo) : bool
  +duracionMinutos() : int
}

class TipoConsulta {
  -nombre : String
  -duracionBase : int
}

class RegistroCambioTurno {
  -fechaHora : DateTime
  -tipoCambio : String
  -detalle : String
  +registrarCambio()
}

class RegistroPresencia {
  -horaLlegada : DateTime
  +registrarLlegada()
}

class EstadoTurno {
  <<enumeration>>
  PENDIENTE
  CONFIRMADO
  CANCELADO
  REPROGRAMADO
  ATENDIDO
  AUSENTE
}

Persona <|-- Paciente
Persona <|-- Profesional
Persona <|-- Secretaria

Profesional "1" *-- "1" Agenda : posee
Agenda "1" *-- "0..*" Turno : administra
Agenda "1" *-- "0..*" Disponibilidad : contiene

Turno "1" --> "1" Paciente : corresponde a
Turno "1" --> "1" Profesional : reservado con
Turno "1" --> "1" TipoConsulta : define
Turno "1" --> "1" IntervaloTiempo : usa
Disponibilidad "1" --> "1" IntervaloTiempo : usa

Turno "1" --> "0..*" RegistroCambioTurno : genera
Turno "1" --> "0..1" RegistroPresencia : puede tener

Secretaria ..> Agenda : opera sobre
release/entrega-final-correcta
