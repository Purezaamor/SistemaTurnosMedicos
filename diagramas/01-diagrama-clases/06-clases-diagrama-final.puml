@startuml
' ============================================
' 1. CLASES BASE (HERENCIA)
' ============================================
class Persona {
  - nombre: String
  - dni: String
  - telefono: String
}

class Paciente {
  - obraSocial: String
  + getHistorial(): void
}

class Medico {
  - especialidad: String
  - matricula: String
  + obtenerTurnos(fecha: Date): List<Turno>
  + getDisponibilidad(fecha: Date): List<Time>
  + setDisponibilidad(fecha: Date, horas: List<Time>): void
  + verDisponibilidad(): void
}

class Secretaria {
  - legajo: String
  + registrarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
  + modificarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
  + eliminarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
  + registrarTurno(paciente: Paciente, fecha: Date, tipo: String): Turno
}

' ============================================
' 2. INTERFACES (ABSTRACCIÓN)
' ============================================
interface INotificador {
  + enviarConfirmacion(paciente: Paciente, mensaje: String): void
  + enviarCancelacion(paciente: Paciente, mensaje: String): void
  + enviarReprogramacion(paciente: Paciente, mensaje: String): void
}

interface IRepositorioTurnos {
  + guardar(turno: Turno): void
  + buscar(id: String): Turno
  + cancelar(id: String): void
}

' ============================================
' 3. CLASES DE DOMINIO
' ============================================
class Agenda {
  - turnos: List<Turno>
  - disponibilidad: List<Disponibilidad>
  + consultarTurnos(fecha: Date): List<Turno>
  + verificarDisponibilidad(fecha: Date, hora: Time): Boolean
  + agregarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
  + eliminarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
  + consultarDisponibilidad(medico: Medico, fecha: Date): List<Time>
  + obtenerTurnos(fecha: Date): List<Turno>
}

class Turno {
  - paciente: Paciente
  - fecha: Date
  - hora: Time
  - estado: String
  + getDetalle(): String
  + cancelar(): void
  + reprogramar(nuevaFecha: Date): void
}

class Disponibilidad {
  - fecha: Date
  - hora: Time
  - disponible: Boolean
}

class Notificador {
  + enviarConfirmacion(paciente: Paciente, mensaje: String): void
  + enviarCancelacion(paciente: Paciente, mensaje: String): void
  + enviarReprogramacion(paciente: Paciente, mensaje: String): void
}

class RepositorioTurnos {
  + guardar(turno: Turno): void
  + buscar(id: String): Turno
  + cancelar(id: String): void
}

' ============================================
' 4. CONTROLADORES Y PANTALLAS
' ============================================
class PantallaTurnos {
  + mostrarConfirmacion(): void
  + mostrarError(): void
  + mostrarHorarios(horarios: List<Time>): void
}

class PantallaAgenda {
  + mostrarAgenda(turnos: List<Turno>): void
  + seleccionarFecha(fecha: Date): void
}

class ControladorTurnos {
  + crearTurno(paciente: Paciente, fecha: Date, tipo: String): Turno
  + cancelarTurno(id: String): void
  + reprogramarTurno(id: String, nuevaFecha: Date): void
}

class ControladorAgenda {
  + obtenerTurnos(fecha: Date): List<Turno>
  + filtrarPorEspecialidad(especialidad: String): List<Turno>
  + administrarDisponibilidad(medico: Medico, fecha: Date, hora: Time): void
}

' ============================================
' 5. RELACIONES DE HERENCIA
' ============================================
Paciente --|> Persona
Medico --|> Persona
Secretaria --|> Persona

' ============================================
' 6. RELACIONES DE ASOCIACIÓN, COMPOSICIÓN Y AGREGACIÓN
' ============================================
Medico "1" --> "1" Agenda
Agenda "1" *-- "0..*" Turno
Agenda "1" o-- "0..*" Disponibilidad
Secretaria --> Medico
Secretaria --> Paciente
Secretaria --> Turno
Turno --> Paciente

' ============================================
' 7. RELACIONES DE DEPENDENCIA E INTERFACES
' ============================================
Notificador ..|> INotificador
RepositorioTurnos ..|> IRepositorioTurnos
ControladorTurnos --> Notificador
ControladorTurnos --> RepositorioTurnos
PantallaTurnos --> ControladorTurnos
PantallaAgenda --> ControladorAgenda
ControladorTurnos --> Turno
ControladorTurnos --> Agenda
ControladorAgenda --> Agenda
@enduml